# Normalize line endings: store LF in the repo, check out native on each OS.
* text=auto

# GDScript and Godot text resources are always LF.
*.gd text eol=lf
*.tscn text eol=lf
*.godot text eol=lf
*.import text eol=lf
*.cfg text eol=lf
*.md text eol=lf

# Binary assets — never touch.
*.png binary
*.webp binary
*.ogg binary
*.wav binary
*.ttf binary
